<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Standard NuGet.org -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    
    <!-- CycoAi GitHub Packages (cross-org access via GitHub App) -->
    <add key="CycoAi-GitHub" value="https://nuget.pkg.github.com/CycoAi/index.json" />
  </packageSources>
  
  <packageSourceCredentials>
    <CycoAi-GitHub>
      <!-- GitHub username (can be any valid GitHub user with access) -->
      <add key="Username" value="github" />
      
      <!-- Token from environment variable (populated by GitHub App in CI) -->
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </CycoAi-GitHub>
  </packageSourceCredentials>
</configuration>
